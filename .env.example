# Copy to .env and fill in. The only secrets needed are for OpenAI, and they are
# used ONLY when llm.provider (or embeddings.provider) is "openai" in config.yaml.
# Everything else is configured in config/config.yaml.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure embeddings (used ONLY when embeddings.provider == "azure_openai").
# AZURE_URL is the full deployment URL with deployment + api-version embedded.
RAG_EMBEDDINGS__AZURE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>/embeddings?api-version=2024-06-01
RAG_EMBEDDINGS__API_KEY=
